# =============================================================================
# Claro — Environment variables
# Copy to .env and fill in values. See src/env.ts for validation rules.
# =============================================================================

# -----------------------------------------------------------------------------
# Payload CMS
# -----------------------------------------------------------------------------
# Required.
PAYLOAD_SECRET=your-payload-secret-min-1-character

# MongoDB connection string
DATABASE_URI=mongodb://localhost:27017/claro

# Optional in dev. Required in production for media uploads (Vercel Blob). Get from Vercel Blob Dashboard.
# BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Stripe (Connect)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx

# Required for webhook signature verification. Get from Stripe Dashboard → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# -----------------------------------------------------------------------------
# URLs (multi-tenant)
# -----------------------------------------------------------------------------
# App base URL (used for redirects, tRPC, checkout)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Root domain for subdomain routing (e.g. example.com → tenant.example.com)
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# Set to "true" to enable subdomain routing (tenant.example.com). "false" for path-based (/tenants/slug).
NEXT_PUBLIC_FEATURE_SUBDOMAIN_ROUTING=false

# -----------------------------------------------------------------------------
# Optional (defaults)
# -----------------------------------------------------------------------------
# NODE_ENV=development
